# Weights & Biases (https://wandb.ai/settings)
WANDB_API_KEY=your_api_key_here
# Optional fallback when wandb.project is not set in experiment YAML.
# Experiment config (Hydra) takes precedence over this value.
WANDB_PROJECT=simclr-fraud
# Your W&B username or team name (must match an account you can write to).
# Leave blank to use the default entity for your API key.
# Example: if logged in as "aiwand", use WANDB_ENTITY=aiwand (NOT a different name).
WANDB_ENTITY=

# Optional: Kaggle credentials for kagglehub (or use ~/.kaggle/kaggle.json)
# KAGGLE_USERNAME=
# KAGGLE_KEY=

# Optional: restrict GPU
# CUDA_VISIBLE_DEVICES=0
